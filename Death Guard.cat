  <sharedProfiles>
    <profile name="Disgustingly Resilient" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="52b9-6c62-d32f-df2c">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">A unit with this ability has the Resilient special rule and in addition has the Feel no pain (8+) special ruleif the unmodified damage of the attack received is 1.


^^**NOTE:**^^ The Resilient rule lowering the damage of an attack of 2 to 1 doesnt trigger the Feel no pain (8+) rule this way.</characteristic>
      </characteristics>
    </profile>
    <profile name="Plague aura" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="4f83-33f2-ddbb-65a1">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Aura]**^^ enemy units within 6” of a unit with this ability receive a Plague token at the start of the assault phase.
This aura is allowed to stack</characteristic>
      </characteristics>
    </profile>
    <profile name="Lord of the Death Guard" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="d1c4-6997-a5b0-e134">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Command ability]**^^ Target one other friendly infantry unit within 6”, it may add +1 to its Hit rolls, until the end phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Living Disease" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="f312-db9e-dd5f-7000">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Once per battle]**^^ The first time a model with this ability is destroyed in a battle round, roll 1d6 in the end phase. On a 2+, set that model back up on the battlefield, as close as possible to where it was destroyed and not locked in combat of any enemy units, with 1d3 wounds remaining.</characteristic>
      </characteristics>
    </profile>
    <profile name="Swift-spreading plague" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="e068-127f-14d8-2111">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">Whenever this model slays a model with a weapon with the Plague special rule, then that units receives two plague tokens instead of just one</characteristic>
      </characteristics>
    </profile>
    <profile name="Gift of Poxes" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="2717-dd95-f764-b52e">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">Add 3” to the range of this model’s Plague aura range</characteristic>
      </characteristics>
      <modifiers>
        <modifier type="replace" value="enemy units within 9” of a unit with this ability" field="f0f1-262f-7fa5-e653" scope="parent" arg="enemy units within 6” of a unit with this ability" position="0" affects="profiles.Ability"/>
      </modifiers>
    </profile>
    <profile name="Shroud of Disease" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="b99a-ef3b-b7fe-575a">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Command ability]**^^ This model and one friendly infantry unit within 6” gain the Shrouded special rule as long it has a Activation token.</characteristic>
      </characteristics>
    </profile>
    <profile name="Master of Destruction" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="6301-f825-7141-ecbe">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Command ability]**^^ Target one friendly infantry unit within 6”, that units ranged weapons with the Plague special rule gain the Rending (9+) special rule, until the end phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Blight Bombardment" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="7385-08d6-efc2-1f59">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Aura]**^^ Friendly units within 6” may gain the Shred special rule with ranged weapons that have the Blast special rule</characteristic>
      </characteristics>
    </profile>
    <profile name="The Seven-fold Chant" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="58e6-24ff-8678-db96">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">When this model performs a Shoot sub-action it may in addition target any enemy units within line of sight. For every Plague token that unit has roll a 1d10, for every result of 7+ that unit adds another plague token to it</characteristic>
      </characteristics>
    </profile>
    <profile name="Revolting Stench" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="3fdc-aab2-43c0-d82a">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Aura]**^^ Enemy units declaring a charge within 12” need to make a Morale test, if failed that units charge fails automatically.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Plague token" id="6bfc-3a37-289d-4080" hidden="false">
      <alias>Plague tokens</alias>
      <description>In the end phase, roll 1d10 for each plague token any enemy unit has; 
^^**&gt;**^^ For every result of 7+ it receives 1 lethal damage
^^**&gt;**^^ For every result of 6 and below it removes a plague token instead
Units can only have a maximum of 7 plague tokens at a time.</description>
    </rule>
    <rule name="Plague" id="8d83-7e01-2cdc-dafb" hidden="false">
      <description>.
^^**•**^^ When a model is slain by a weapon with this ability, its unit receives a Plague token.
^^**•**^^ When a model takes 3 or more damage from one attack with this ability its unit receives a Plague token.</description>
    </rule>
  </sharedRules>
  <categoryEntries>
    <categoryEntry name="Plague Weapon" id="3674-1046-d921-9004" hidden="false"/>
  </categoryEntries>
</catalogue>
