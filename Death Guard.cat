      </characteristics>
    </profile>
    <profile name="Affliction" typeId="c3a3-f651-e6b6-5382" typeName="Discipline" hidden="false" id="284b-69f8-d31b-6ea3">
      <characteristics>
        <characteristic name="Surge" typeId="20aa-b15f-e378-e075">5</characteristic>
        <characteristic name="Target" typeId="2e9b-b00d-6a93-c070">A visible non-vehicle enemy model within 12”.
You may target this power as with the Sniper special rule.</characteristic>
        <characteristic name="Fail" typeId="9f04-a045-af34-18bc"/>
        <characteristic name="Succes" typeId="1ba0-f8a9-fa4d-9143">Roll 1d10, if the result is equal to or above the targets Toughness. Then the target needs to make a Armour save roll. Dealing 1d3 damage if failed with the Instant death special rule</characteristic>
        <characteristic name="Major Succes" typeId="dfc3-bf8a-d2f5-5a0d"/>
        <characteristic name="Perils of the Warp" typeId="cc25-1cd5-b9b4-7ad1">Rolling two 1s or two 10s is a Perils of the Warp</characteristic>
      </characteristics>
