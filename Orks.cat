      <profiles>
        <profile name="Bosspole" typeId="50ab-0b17-e88f-4ab9" typeName="Gear" hidden="false" id="9fb3-fbc2-6d03-61e7">
          <characteristics>
            <characteristic name="Description" typeId="0dfb-289c-ce0b-ead7">**^^[Aura]^^** Units within 6” of a unit with a bosspole that fail a morale test in the morale phase may take one lethal damage to add 1 to the die result to the morale test, this may be done multiple times.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
