    <profile name="Terminator Armour" typeId="9a4c-9cfd-1cac-e423" typeName="Wargear" hidden="false" id="1424-5975-578e-967b">
      <characteristics>
        <characteristic name="Description" typeId="3ead-b5a1-be56-cfe1">The following properties are added to the model.
^^**•**^^ Its Movement becomes 5”,
^^**•**^^ Its Toughness increases with +1.
^^**•**^^ Increases its Wounds with +1.
^^**•**^^ Its Armour Save becomes 3+.
^^**•**^^ It gains the Deepstrike special rule.
^^**•**^^ It gains the Relentless special rule.
^^**•**^^ It gains an 8+ invulnerable save.
^^**•**^^ It gains the Size 2 keyword instead of Size 1 if it has it.</characteristic>
      </characteristics>
    </profile>
    <profile name="Mantle of Virulence" typeId="9a4c-9cfd-1cac-e423" typeName="Wargear" hidden="false" id="8c14-5b0b-6fb4-5382">
      <characteristics>
        <characteristic name="Description" typeId="3ead-b5a1-be56-cfe1">Lords of Virulence receives the Master of Destruction and Blight Bombardment abilities</characteristic>
      </characteristics>
    </profile>
    <profile name="Blight Racks" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="805c-7e5f-3572-af58">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Friendly infantry units within 6” receive the following benefits to its Grenade type weapons:
• Poison (6+) special rule.
• Lethal (9+) speciale rule.</characteristic>
      </characteristics>
    </profile>
    <profile name="Pestilential Explosion" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="31e9-11ca-ab0b-a2d7">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">When this model is slain it might explode like a vehicle with 10 wounds, ^^**roll 1d10 it may trigger the explosion with a 6+.**^^</characteristic>
      </characteristics>
    </profile>
    <profile name="Mantle of Corruption" typeId="9a4c-9cfd-1cac-e423" typeName="Wargear" hidden="false" id="b69f-bead-c7f3-7eff">
      <characteristics>
        <characteristic name="Description" typeId="3ead-b5a1-be56-cfe1">Lords of Poxes receives the Gift of Poxes and Shroud of Disease abilities</characteristic>
