    <selectionEntry type="upgrade" import="true" name="Mega armour" hidden="false" id="6f32-d0a0-5c77-c0ce">
      <rules>
        <rule name="Mega armour" id="2713-608f-0ed8-d67a" hidden="false">
          <description>A model with mega armour gains the following:
^^**•**^^ Has a 4+ Armour Save.
^^**•**^^ Its Wounds increases with +1.
^^**•**^^ Its Toughness increases with +1.
^^**•**^^ It gains the Resilient special rule.
^^**•**^^ Slow and purposeful special rule.
^^**•**^^ The model becomes size 3 instead of size 2.</description>
        </rule>
      </rules>
      <categoryLinks>
        <categoryLink name="Gear" hidden="false" id="2bc8-de08-1ea4-8079" targetId="5fd4-033f-3535-2b2b" primary="true"/>
      </categoryLinks>
