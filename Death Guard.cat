    <selectionEntry type="upgrade" import="true" name="Terminator Armour" hidden="false" id="e621-2587-2305-8e7b">
      <profiles>
        <profile name="Terminator Armour" typeId="50ab-0b17-e88f-4ab9" typeName="Gear" hidden="false" id="4cf4-6de2-04af-5830">
          <characteristics>
            <characteristic name="Description" typeId="0dfb-289c-ce0b-ead7">The following properties are added to the model.
^^**•**^^ Its Movement becomes 5”,
^^**•**^^ Its Toughness increases with +1.
^^**•**^^ Increases its Wounds with +1.
^^**•**^^ Its Armour Save becomes 3+.
^^**•**^^ It gains the Deepstrike special rule.
^^**•**^^ It gains the Relentless special rule.
^^**•**^^ It gains an 8+ invulnerable save.
^^**•**^^ It gains the Size 2 keyword instead of Size 1 if it has it.</characteristic>
          </characteristics>
        </profile>
      </profiles>
      <constraints>
        <constraint type="max" value="1" field="selections" scope="parent" shared="true" id="a170-6656-2bb0-146a" includeChildSelections="false"/>
        <constraint type="min" value="0" field="selections" scope="parent" shared="true" id="80f3-0707-d6fb-bf26" includeChildSelections="false"/>
      </constraints>
      <modifierGroups>
        <modifierGroup type="and">
          <modifiers>
            <modifier type="set" value="3+" field="ae5e-affd-e329-09d3" scope="parent" affects="profiles.Model"/>
