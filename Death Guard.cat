    <profile name="Pestilential Fallout" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="ca4e-6284-d597-fffc">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">Whenever this model makes a Psychic test, for each die that results in a 7, it may deal 1 Lethal damage to one visible enemy unit within 7”.</characteristic>
      </characteristics>
    </profile>
