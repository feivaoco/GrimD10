          <characteristics>
            <characteristic name="Description" typeId="0dfb-289c-ce0b-ead7">^^**[Aura]**^^ This model, and all infantry models within 6”, receive a 8+ invulnerable save against any ranged attacks. If the model is embarked in a vehicle or is a vehicle, then the vehicle receives a 8+ invulnerable save against any ranged attacks instead.</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
    <selectionEntry type="upgrade" import="true" name="’Eavy plates" hidden="false" id="4070-b9f3-e8b1-6c2d">
