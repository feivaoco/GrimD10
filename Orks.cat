          <characteristics>
            <characteristic name="Description" typeId="0dfb-289c-ce0b-ead7">A model with ’Eavy plates may increase its Armour Save with a +1 modifier (a Sv of 6+ becomes a Sv of 5+), decrease its movement characteristic by -2</characteristic>
          </characteristics>
        </profile>
      </profiles>
    </selectionEntry>
