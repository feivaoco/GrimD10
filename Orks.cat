    <selectionEntry type="upgrade" import="true" name="Grot Gunner" hidden="false" id="cb48-f8dd-2d12-af22">
      <rules>
        <rule name="Grot Gunner" id="1484-9d78-066b-5e07" hidden="false">
          <description>A model with a grot gunner may add +1 to hit rolls to one ranged assault type weapon when shooting.</description>
        </rule>
