  <sharedProfiles>
    <profile name="Breaking’ heads" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="75b1-5773-d97b-d2d3">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Aura]**^^ if a friendly unit within 6” fails a morale test, this unit may deal 1d3 lethal wounds to that unit but the Morale test is then considered to have been succesfull.</characteristic>
      </characteristics>
    </profile>
    <profile name="Command" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="187e-1187-2836-54b7">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">When a unit with this special rule activates, it can order another unit within 6&quot; (or in reserves, if both units are in reserves) to activate as part of a shared activation. Both units are treated as one and must be within 2&quot; of each other when entering the battlefield from reserves.
If the other unit has the Command special rule, it cannot use it during this shared activation.</characteristic>
      </characteristics>
    </profile>
    <profile name="Da Warboss" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="5caa-297b-f805-cd2c">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">^^**[Command ability]**^^ Target one friendly infantry or cavalry unit within 6”, that unit either gains the Furious charge special rule OR gains the Twin linked special rule on all its ranged weapons, until the end phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Dakka dakka" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="84bf-05ea-d0f4-ae4a">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">For each unmodified ranged weapon hit roll result of 10, the attack scores one additional successful hit.</characteristic>
      </characteristics>
    </profile>
    <profile name="Ere we go" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="706f-e053-5185-f11c">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">A unit with this ability may re-roll the charge roll die results of 1</characteristic>
      </characteristics>
    </profile>
    <profile name="Open-topped" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="5e4b-97f6-cddd-4150">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">When an open-topped vehicle suffers “mechanical damage,” add +1 to the result.</characteristic>
      </characteristics>
    </profile>
    <profile name="Ramshackle" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="d64a-7fa9-484a-a95f">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">If an armour save die roll result of 1 is rolled with this vehicle, halve the damage of that attack (minimum 1).</characteristic>
      </characteristics>
    </profile>
    <profile name="Sentinel" typeId="52eb-5f98-0a80-002c" typeName="Ability" hidden="false" id="5898-908c-f043-2b50">
      <characteristics>
        <characteristic name="Description" typeId="f0f1-262f-7fa5-e653">This unit doesn&apos;t have to spend it&apos;s activation token to fire Overwatch when itself is targeted by a charge. This means that this unit can fire overwatch multiple times a round.</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
