  <sharedProfiles>
    <profile name="Disgustingly Resilient" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="52b9-6c62-d32f-df2c">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">A unit with this ability has the Resilient special rule and in addition has the Feel no pain (8+) special rule if the unmodified damage of the attack received is 1.
^^**NOTE:**^^ The Resilient rule lowering the damage of an attack of 2 to 1 doesnt trigger the Feel no pain (8+) rule this way.</characteristic>
      </characteristics>
    </profile>
    <profile name="Plague aura" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="4f83-33f2-ddbb-65a1">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ enemy units within X” of a unit with this ability receive a Plague token at the start of the assault phase.
This aura is allowed to stack</characteristic>
      </characteristics>
    </profile>
    <profile name="Lord of the Death Guard" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="d1c4-6997-a5b0-e134">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Command ability]**^^ Target one other friendly infantry unit within 6”, it may add +1 to its Hit rolls, until the end phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Living Disease" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="f312-db9e-dd5f-7000">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Once per battle]**^^ The first time a model with this ability is destroyed in a battle round, roll 1d6 in the end phase. On a 2+, set that model back up on the battlefield, as close as possible to where it was destroyed and not locked in combat of any enemy units, with 1d3 wounds remaining.</characteristic>
      </characteristics>
    </profile>
    <profile name="Swift-spreading plague" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="e068-127f-14d8-2111">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">Whenever this model slays a model with a weapon with the Plague special rule, then that units receives two plague tokens instead of just one</characteristic>
      </characteristics>
    </profile>
    <profile name="Gift of Poxes" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="2717-dd95-f764-b52e">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">Add 3” to the range of this model’s Plague aura range</characteristic>
      </characteristics>
    </profile>
    <profile name="Shroud of Disease" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="b99a-ef3b-b7fe-575a">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Command ability]**^^ This model and one friendly infantry unit within 6” gain the Shrouded special rule as long it has an Activation token.</characteristic>
      </characteristics>
    </profile>
    <profile name="Master of Destruction" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="6301-f825-7141-ecbe">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Command ability]**^^ Target one friendly infantry unit within 6”, that units ranged weapons with the Plague special rule gain the Rending (9+) special rule, until the end phase.</characteristic>
      </characteristics>
    </profile>
    <profile name="Blight Bombardment" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="7385-08d6-efc2-1f59">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Friendly units within 6” may gain the Shred special rule with ranged weapons that have the Blast special rule</characteristic>
      </characteristics>
    </profile>
    <profile name="The Seven-fold Chant" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="58e6-24ff-8678-db96">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">When this model performs a Shoot sub-action it may in addition target any enemy units within line of sight. For every Plague token that unit has roll a 1d10, for every result of 7+ that unit adds another plague token to it</characteristic>
      </characteristics>
    </profile>
    <profile name="Revolting Stench" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="3fdc-aab2-43c0-d82a">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Enemy units declaring a charge within 12” need to make a Morale test, if failed that units charge fails automatically.</characteristic>
      </characteristics>
    </profile>
    <profile name="Sickening Vitality" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="2091-644b-9084-7e4a">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Friendly infantry units within 12” add a +1 modifier to its Movement skill.</characteristic>
      </characteristics>
    </profile>
    <profile name="Tocsin of Misery" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="8fea-3b04-0abc-9552">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Enemy units within 12” suffer a -1 penalty to its morale tests.</characteristic>
      </characteristics>
    </profile>
    <profile name="Empyric Malaise" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="331b-bebf-7af7-962d">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Enemy psyker units within 12” suffer a +1 penalty to the surge value of its psychic powers.</characteristic>
      </characteristics>
    </profile>
