    <profile name="Tainted Narthecium" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="1528-7ad9-a59e-9a56">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ Friendly infantry units within 6” add a +1 modifier to its Feel no pain rolls.</characteristic>
      </characteristics>
    </profile>
    <profile name="Revitalising Malignancy" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="2703-4362-aa85-b81e">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">After this unit has performed an advance or run action and is not locked in combat, it may target one friendly infantry model within 2”. 
Apply one of the following:
^^**•**^^ That unit regains 1d3 wounds.
^^**•**^^ Roll 1d10, on a result of 6+ revive one slain model back to the unit with one wound remaining.</characteristic>
      </characteristics>
    </profile>
    <profile name="Diseased Terminator Armour" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="ade9-4be3-25d8-092e">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">Models in this unit have a 8+ invulnerable save</characteristic>
      </characteristics>
    </profile>
    <profile name="Curse of the Walking Pox" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="9f09-a6c5-3f8e-77c2">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ One allied poxwalker unit within 6” may add one poxwalker model into the unit whenever an non-poxwalker infantry or cavalry model within 6” dies. Adding a model this way into the unit must be done outside of 1” of enemy models</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemon" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="80b6-11ac-e8c8-26d7">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">Models in this unit have a 9+ invulnerable save</characteristic>
      </characteristics>
    </profile>
    <profile name="Daemon engine" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="4d88-48d3-14b8-07da">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">When this unit spends its activation token for an action it may immediately regain 1 wound.</characteristic>
      </characteristics>
    </profile>
    <profile name="Putrid Explosion" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="258b-8958-e485-ef79">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">This vehicle explodes on a roll of 7+ instead of a 9+</characteristic>
      </characteristics>
    </profile>
    <profile name="Putrescent Fog" typeId="746a-4338-5ebe-6106" typeName="Special Rule" hidden="false" id="7e5f-ed41-c72d-94ec">
      <characteristics>
        <characteristic name="Description" typeId="e31c-dba6-82c9-32db">^^**[Aura]**^^ friendly infantry units within 6” gain the benefit of Light cover (8+).</characteristic>
      </characteristics>
    </profile>
  </sharedProfiles>
  <sharedRules>
    <rule name="Plague token" id="6bfc-3a37-289d-4080" hidden="false">
      <alias>Plague tokens</alias>
      <description>In the end phase, roll 1d10 for each plague token any enemy unit has; 
^^**&gt;**^^ For every result of 7+ it receives 1 lethal damage
^^**&gt;**^^ For every result of 6 and below it removes a plague token instead
Units can only have a maximum of 7 plague tokens at a time.</description>
    </rule>
    <rule name="Plague" id="8d83-7e01-2cdc-dafb" hidden="false">
      <description>^^**•**^^ When a model is slain by a weapon with this ability, its unit receives a Plague token.
^^**•**^^ When a model takes 3 or more damage from one attack with this ability its unit receives a Plague token.</description>
    </rule>
    <rule name="Sigil of Corruption" id="ddd5-bebf-f6cd-10e4" hidden="false">
      <description>The model gains a 6+ invulnerable save</description>
    </rule>
    <rule name="Disgustingly Resilient" id="e3c0-76fc-d2b6-0d06" hidden="false">
      <description>A unit with this ability has the Resilient special rule and in addition has the Feel no pain (8+) special ruleif the unmodified damage of the attack received is 1.




^^**NOTE:**^^ The Resilient rule lowering the damage of an attack of 2 to 1 doesnt trigger the Feel no pain (8+) rule this way.</description>
    </rule>
    <rule name="Chimes of contagion" id="57ac-d0fa-531b-db4e" hidden="false">
      <description>Increase this units Plague aura by 3”.</description>
    </rule>
    <rule name="Living Disease" id="f781-1bf3-3b13-ee4e" hidden="false">
      <description>^^**[Once per battle]**^^ The first time a model with this ability is destroyed in a battle round, roll 1d6 in the end phase. On a 2+, set that model back up on the battlefield, as close as possible to where it was destroyed and not locked in combat of any enemy units, with 1d3 wounds remaining.</description>
    </rule>
    <rule name="Plague aura" id="71a8-44af-1c8d-e017" hidden="false">
      <description>^^**[Aura]**^^ enemy units within 6” of a unit with this ability receive a Plague token at the start of the assault phase.
This aura is allowed to stack</description>
    </rule>
    <rule name="Lord of the Death Guard" id="0787-aa38-e846-15e7" hidden="false">
      <description>^^**[Command ability]**^^ Target one other friendly infantry unit within 6”, it may add +1 to its Hit rolls, until the end phase.</description>
    </rule>
    <rule name="Mantle of Contagion" id="ee84-beb9-2391-8d9a" hidden="false">
      <description>Lord of Contagion receives the Living Disease and Swift-spreading plague abilities</description>
    </rule>
    <rule name="Swift-spreading plague" id="f750-9c85-787c-cc27" hidden="false">
      <description>Whenever this model slays a model with a weapon with the Plague special rule, then that units receives two plague tokens instead of just one</description>
    </rule>
    <rule name="Blight Bombardment" id="2a34-4c17-0b1d-c497" hidden="false">
      <description>^^**[Aura]**^^ Friendly units within 6” may gain the Shred special rule with ranged weapons that have the Blast special rule</description>
    </rule>
    <rule name="Empyric Malaise" id="ff2b-5577-64b3-ce1f" hidden="false">
      <description>^^**[Aura]**^^ Enemy psyker units within 12” suffer a +1 penalty to the surge value of its psychic powers.</description>
    </rule>
    <rule name="Gift of Poxes" id="8774-b466-55a0-1a35" hidden="false">
      <description>Add 3” to the range of this model’s Plague aura range</description>
    </rule>
    <rule name="Master of Destruction" id="64c9-0dce-c9b4-9bd5" hidden="false">
      <description>^^**[Command ability]**^^ Target one friendly infantry unit within 6”, that units ranged weapons with the Plague special rule gain the Rending (9+) special rule, until the end phase.</description>
    </rule>
    <rule name="Revolting Stench" id="1bba-9632-e78b-35c1" hidden="false">
      <description>^^**[Aura]**^^ Enemy units declaring a charge within 12” need to make a Morale test, if failed that units charge fails automatically.</description>
    </rule>
    <rule name="Shroud of Disease" id="bbce-c83d-bf91-8096" hidden="false">
      <description>^^**[Command ability]**^^ This model and one friendly infantry unit within 6” gain the Shrouded special rule as long it has an Activation token.</description>
    </rule>
    <rule name="Sickening Vitality" id="d969-0485-8b6b-b21e" hidden="false">
      <description>^^**[Aura]**^^ Friendly infantry units within 12” add a +1 modifier to its Movement skill.</description>
    </rule>
    <rule name="The Seven-fold Chan" id="71a6-d54e-5052-4bc9" hidden="false">
      <description>When this model performs a Shoot sub-action it may in addition target any enemy units within line of sight. For every Plague token that unit has roll a 1d10, for every result of 7+ that unit adds another plague token to it</description>
    </rule>
    <rule name="Tocsin of Misery" id="4ec7-8ee8-bf00-9087" hidden="false">
      <description>^^**[Aura]**^^ Enemy units within 12” suffer a -1 penalty to its morale tests.</description>
    </rule>
    <rule name="Terminator Armour" id="5d93-93f4-6810-1915" hidden="false">
      <description>The following properties are added to the model.
^^**•**^^ Its Movement becomes 5”,
^^**•**^^ Its Toughness increases with +1.
^^**•**^^ Increases its Wounds with +1.
^^**•**^^ Its Armour Save becomes 3+.
^^**•**^^ It gains the Deepstrike special rule.
^^**•**^^ It gains the Relentless special rule.
^^**•**^^ It gains an 8+ invulnerable save.
^^**•**^^ It gains the Size 2 keyword instead of Size 1 if it has it.</description>
    </rule>
    <rule name="Mantle of Virulence" id="1065-82ba-2d4a-1a0c" hidden="false">
      <description>Lords of Virulence receives the Master of Destruction and Blight Bombardment abilities</description>
    </rule>
  </sharedRules>
  <categoryEntries>
    <categoryEntry name="Plague Weapon" id="3674-1046-d921-9004" hidden="false"/>
  </categoryEntries>
